rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isVerified() {
      return isAuthenticated() && (
        request.auth.token.email_verified == true || 
        request.auth.token.firebase.sign_in_provider == 'google.com'
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // super-admins bypass exists() checks to prevent list-query locks
    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.uid == "uVa43jYv4IUCt1XRsSO8inSrtiA2" ||
        (request.auth.token.email != null && request.auth.token.email == "outgame954@gmail.com")
      );
    }

    function isAdmin() {
      return isSuperAdmin() || (
        isAuthenticated() && 
        request.auth.token.email != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidMenuItem(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'available']) &&
             data.name is string && data.name.size() > 0 &&
             data.price is number &&
             data.category is string &&
             data.available is bool &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() < 2000)) &&
             (!('description' in data) || (data.description is string && data.description.size() < 1000));
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['userId', 'firstName', 'lastName', 'phone', 'userEmail', 'date', 'location', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.firstName is string &&
             data.status == 'pending';
    }

    function isValidLocation(data) {
      return data.keys().hasAll(['address', 'updatedAt']) &&
             data.address is string &&
             data.updatedAt is timestamp &&
             (!('latitude' in data) || data.latitude is number) &&
             (!('longitude' in data) || data.longitude is number);
    }

    function isValidReview(data) {
      return data.keys().hasAll(['userId', 'userName', 'rating', 'text', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.userName is string &&
             data.rating is number &&
             data.createdAt is timestamp;
    }

    function isValidGalleryImage(data) {
      return data.keys().hasAll(['url', 'createdAt']) &&
             data.url is string && data.url.size() < 2000 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Match Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && 
                            (!('role' in incoming()) || incoming().role == 'client' || isSuperAdmin());
    }

    match /menu/{itemId} {
      allow get, list: if true;
      allow write: if isAdmin() && isValidMenuItem(incoming());
      allow delete: if isAdmin();
    }

    match /settings/{docId} {
      allow get: if true;
      allow list, write: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow get, list: if isAdmin() || (isAuthenticated() && (existing().userId == request.auth.uid));
      allow create: if isVerified() && isValidBooking(incoming());
      allow update: if isAdmin() || (isAuthenticated() && existing().userId == request.auth.uid && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
                       incoming().status == 'cancelled');
      allow delete: if isAdmin();
    }

    match /location/{docId} {
      allow get, list: if true;
      allow write: if isAdmin() && isValidLocation(incoming());
    }

    match /admins/{email} {
      allow get: if isAuthenticated() && request.auth.token.email == email;
      allow list: if isAdmin();
      allow write: if isSuperAdmin();
    }

    match /reviews/{reviewId} {
      allow get, list: if true;
      allow create: if isAuthenticated() && isValidReview(incoming());
      allow delete: if isAdmin() || (isAuthenticated() && existing().userId == request.auth.uid);
    }

    match /gallery/{imageId} {
      allow get, list: if true;
      allow create: if isAdmin() && isValidGalleryImage(incoming());
      allow delete: if isAdmin();
    }

    match /test/connection {
      allow get: if true;
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
